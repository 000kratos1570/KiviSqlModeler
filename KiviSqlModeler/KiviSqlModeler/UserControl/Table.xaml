<UserControl x:Class="KiviSqlModeler.UserControl.Table"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KiviSqlModeler.UserControl"
             mc:Ignorable="d" 
             d:DesignHeight="80" d:DesignWidth="300">
    <DockPanel>
        <TextBlock Name="tableName" DockPanel.Dock="Top" TextAlignment="Left" Text="Таблица1"/>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.ColumnSpan="3" Grid.RowSpan="2" BorderThickness="1" BorderBrush="Black">
                <Separator Margin="3, 20" Background="Black" Height="1"/>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
